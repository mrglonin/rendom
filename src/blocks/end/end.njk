{% from "blocks/components/decor.njk" import decor %}
{% from "blocks/components/bottom-actions.njk" import bottomActions %}
{% from "blocks/components/navigation.njk" import navigation %}
{% macro end(props = {}) %}
{% set statsItems = props.statsItems or [
{
"percent": 33,
"label": "Цифро-<br>оптимисты",
"accent": true
},
{
"percent": 15,
"label": "Полные права <br>человека"
},
{
"percent": 27,
"label": "Участники движения <br>за дружественный ИИ"
},
{
"percent": 29,
"label": "Ограниченные <br>гражданские права",
"accent": true
},
{
"percent": 13,
"label": "Техно-<br>скептики"
},
{
"percent": 36,
"label": "Имущественные права <br>без гражданских"
},
{
"percent": 40,
"label": "Луддиты"
},
{
"percent": 9,
"label": "Статус <br>сложного имущества"
},
{
"percent": 11,
"label": "Отсутствие <br>правового статуса"
}
] %}
<div
    class="end{% if props.active %} end--active{% endif %}{% if props.hidden %} end--hidden{% endif %}{{ (' ' ~ props.className) if props.className else '' }}">
    <div class="end__layers">
        <div class="end__layer end__layer--base">
            <picture class="end__media">
                <img src="images/end-base.jpg" alt="base">
            </picture>
        </div>
        <div class="end__layer end__layer--artwork">
            <picture class="end__media">
                <img src="images/end-artwork-img.png" alt="bg">
            </picture>
        </div>
        <div class="end__layer end__layer--glow-blue"></div>
        <div class="end__layer end__layer--glow-green-top"></div>
        <div class="end__layer end__layer--glow-green-bottom"></div>
        <div class="end__layer end__layer--glow-gradient-right"></div>
    </div>
    <div class="container">
        <div class="end__inner">
            <div class="end__intro">
                <h2 class="end__title">
                    <span class="end__title-line end__title-line--accent">Спасибо</span>
                    <span class="end__title-line end__title-line--accent">за ваши ответы!</span>
                </h2>
                <div class="end__texts">
                    <p class="end__description">
                        Вы определили свои предпочтения <br>
                        о статусе искусственного интеллекта <br>
                        в обществе будущего. Помните: искусственный <br>
                        интеллект станет для нас тем, кем мы <br>
                        позволим ему быть.
                    </p>
                    <p class="end__description">
                        17 ноября 2025 года Казахстан — <br>
                        первым в Центральной Азии — принял закон <br>
                        об искусственном интеллекте, который уже <br>
                        формирует правила этого будущего.
                    </p>
                </div>
            </div>
            <div class="end__stats">
                <div class="end__stats-title">
                    [ответы других посетителей]:
                </div>
                <ul class="end__stats-list">
                    {% for item in statsItems %}
                    <li class="end__stats-item{% if item.accent %} end__stats-item--accent{% endif %}">
                        <div class="end__stats-value">
                            <div class="end__stats-bar" style="width: {{ item.percent }}%;"></div>
                            <div class="end__stats-number">
                                {{ item.percent }}
                                <span class="end__stats-unit">%</span>
                            </div>
                        </div>
                        <div class="end__stats-text">{{ item.label | safe }}</div>
                    </li>
                    {% endfor %}
                </ul>
                <div class="end__stats-footer">
                    <div class="end__stats-footer-mark">
                        <svg width="11" height="35" viewBox="0 0 11 35" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M1 0L1 34L11 34" stroke="white" stroke-width="2" />
                        </svg>
                    </div>
                    <div class="end__stats-footer-text">
                        разделяют
                        <span>
                            [ваш]
                        </span>
                        выбор
                    </div>
                </div>
            </div>
            {{ bottomActions({
                "elementClass": "end__bottom",
                "submitText": "завершить",
                "backIcon": "end"
            }) }}
            {{ navigation({"className": "end__navigation"}) }}
        </div>
    </div>
</div>
{% endmacro %}

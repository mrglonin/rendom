{% set statuses = props.statuses or [
{
"label": "отсутствие прав",
"title": "Отсутствие правового статуса",
"summary": "Для вас ИИ должен оставаться инструментом без самостоятельного правового положения."
},
{
"label": "статус сложного имущества",
"title": "Статус сложного имущества",
"summary": "Вы допускаете специальный режим регулирования, но без признания полноценной субъектности."
},
{
"label": "имущественные права без гражданских",
"title": "Имущественные права без гражданских",
"summary": "Вы допускаете для ИИ экономическую субъектность, но не полный доступ к общественной и политической жизни."
},
{
"label": "ограниченные гражданские права",
"title": "Ограниченные гражданские права",
"summary": "Вы готовы признать за ИИ часть базовых прав, если это потребуется для справедливого сосуществования."
},
{
"label": "полные права человека",
"title": "Полные права человека",
"summary": "Вы допускаете полноценное правовое равенство ИИ и человека при достижении сопоставимого уровня сознания."
}
] %}
<div class="results results--hidden{{ (' ' ~ props.className) if props.className else '' }}">
    <div class="results__inner">
        <ul class="results__list">
            {% for attitude in attitudes %}
            {% set attitudeIndex = loop.index0 %}
            {% for status in statuses %}
            {% set cardNumber = (attitudeIndex * (statuses | length)) + loop.index %}
            <li class="results__item">
                <div
                    class="results__card{% if cardNumber == 1 %} results__card--active{% endif %}"
                    data-card-index="{{ cardNumber }}"
                    data-assessment-index="{{ attitudeIndex }}"
                    data-status-index="{{ loop.index0 }}">
                    {% call head({
                        "suptitle": "raintears.runnerk"
                    }) %}
                        {{ resultsHeadIcons() }}
                    {% endcall %}
                    <div class="results__wrapper">
                        <div class="results__media">
                            <div class="results__figure results__figure--left">
                                <picture class="results__picture">
                                    <img src="images/result-img-left-{{ cardNumber }}.jpg" alt="{{ attitude.title }}">
                                </picture>
                            </div>
                            <div class="results__figures">
                                <div class="results__figure results__figure--top">
                                    <picture class="results__picture">
                                        <img src="images/result-img-top.svg" alt="">
                                    </picture>
                                    {{ decor({"elementClass": "results__decor", "className": "decor--medium
                                    decor--grey"}) }}
                                </div>
                                <div class="results__figure results__figure--bottom">
                                    <picture class="results__picture">
                                        <img src="images/result-img-bottom.svg" alt="">
                                    </picture>
                                    {{ decor({"elementClass": "results__decor", "className": "decor--medium
                                    decor--grey"}) }}
                                </div>
                            </div>
                        </div>
                        <div class="results__body">
                            <div class="results__meta">
                                <ul class="results__meta-list">
                                    <li class="results__meta-item">
                                        <div class="results__meta-title">[статус ИИ]:</div>
                                        <div class="results__meta-value">
                                            <svg width="11" height="31" viewBox="0 0 11 31" fill="none"
                                                xmlns="http://www.w3.org/2000/svg">
                                                <path d="M1 0L1 30L11 30" stroke="#D1CADC" stroke-width="2" />
                                            </svg>
                                            <span>{{ status.label }}</span>
                                        </div>
                                    </li>
                                    <li class="results__meta-item">
                                        <div class="results__meta-title">[ваше отношение]:</div>
                                        <div class="results__meta-value">
                                            <svg width="11" height="31" viewBox="0 0 11 31" fill="none"
                                                xmlns="http://www.w3.org/2000/svg">
                                                <path d="M1 0L1 30L11 30" stroke="#D1CADC" stroke-width="2" />
                                            </svg>
                                            <span>{{ attitude.label }}</span>
                                        </div>
                                    </li>
                                </ul>
                                <div class="results__meta-icon">
                                    {{ resultsMetaIcon(attitudeIndex + 1) }}
                                </div>
                            </div>
                            <h5 class="results__title">Результаты теста</h5>
                            <div class="results__content">
                                <p class="results__text">
                                    {{ resultTexts[cardNumber - 1] | safe }}
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </li>
            {% endfor %}
            {% endfor %}
        </ul>
    </div>
    {{ bottomActions({
        "elementClass": "results__bottom",
        "submitText": "далее",
        "submitIcon": true
    }) }}
</div>
{% endmacro %}

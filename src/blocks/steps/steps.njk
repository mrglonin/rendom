{% macro steps(props = {}) %}
    {% set total = props.total or 1 %}
    {% set current = props.current or 1 %}
    <div class="steps{{ (' ' ~ props.className) if props.className else '' }}">
        <ul class="steps__list">
            {% for index in range(1, total + 1) %}
                <li class="steps__item{% if index == current %} steps__item--active{% endif %}">
                    <div class="steps__circle"></div>
                    {% if index < total %}
                        <div class="steps__line"></div>
                    {% endif %}
                </li>
            {% endfor %}
        </ul>
    </div>
{% endmacro %}

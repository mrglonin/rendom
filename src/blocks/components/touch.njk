{% macro touch(props = {}) %}
{% set textLines = props.textLines or ["коснитесь", "экрана"] %}
<div class="touch{{ (' ' ~ props.className) if props.className else '' }}">
    <div class="touch__icon">
        <svg width="81" height="80" viewBox="0 0 81 80" fill="none"
            xmlns="http://www.w3.org/2000/svg">
            <path
                d="M9.42745 0.385773C12.0647 -0.692134 15.079 0.566253 16.1601 3.19597L32.515 42.9791H37.5871L31.5408 28.1333C30.4709 25.5062 31.7339 22.511 34.3651 21.4355C37.0083 20.3553 40.0286 21.6216 41.1036 24.2606L48.7278 42.9791H54.116L48.478 29.2648C47.3971 26.6352 48.6584 23.6301 51.2955 22.5522C53.9328 21.4743 56.9471 22.732 58.0281 25.3617L65.2709 42.9791H69.6864L65.0693 31.748C63.9759 29.0881 65.2521 26.0479 67.9196 24.9575C70.5872 23.8672 73.636 25.1396 74.7295 27.7996L80.9699 42.9791L80.9662 42.9799C80.9656 62.9674 64.7165 79.1705 44.6715 79.1706H5.6477C2.52869 79.1704 0 76.6492 0 73.5391C6.98518e-05 70.429 2.52873 67.9077 5.6477 67.9075H21.404V43.0859L6.60992 7.0991C5.52889 4.46941 6.79022 1.46371 9.42745 0.385773Z"
                fill="currentColor" />
        </svg>
    </div>
    {% if textLines | select | list | length %}
    <div class="touch__text">
        {% for line in textLines %}
        {% if line %}
        <span>{{ line }}</span>
        {% endif %}
        {% endfor %}
    </div>
    {% endif %}
</div>
{% endmacro %}

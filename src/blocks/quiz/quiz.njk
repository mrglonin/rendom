{% macro quiz(props = {}) %}
{% set items = props.items or [] %}
{% set groups = props.groups or [] %}
{% set current = props.current or 1 %}
<div class="quiz{{ (' ' ~ props.className) if props.className else '' }}">
    <div class="quiz__questions question-cards">
        <div class="question-cards__backdrop">
            <div class="question-cards__backdrop-item question-card">
                {{ head({
                    "theme": "accent",
                    "suptitle": ""
                }) }}
                <div class="question-card__body"></div>
            </div>
            <div class="question-cards__backdrop-item question-card">
                {{ head({
                    "theme": "accent",
                    "suptitle": ""
                }) }}
                <div class="question-card__body"></div>
            </div>
        </div>
        <ul class="question-cards__list">
            {% for item in items %}
            <li class="question-cards__item question-card{% if loop.index == current %} question-card--active{% endif %}">
                {% call head({
                    "theme": "accent",
                    "suptitle": item.suptitle or "[ВОПРОС " ~ loop.index ~ "/" ~ (items | length) ~ "].exe"
                }) %}
                    {{ questionCardIcons(loop.index) }}
                {% endcall %}
                <div class="question-card__body">
                    <p class="question-card__text">{{ item.text | safe }}</p>
                </div>
            </li>
            {% endfor %}
        </ul>
    </div>
    <div class="quiz__answers answer-groups">
        <form class="answer-groups__form" action="#">
            <ul class="answer-groups__list">
                {% for group in groups %}
                {% set groupIndex = loop.index %}
                <li class="answer-groups__item{% if loop.index == current %} answer-groups__item--active{% endif %}">
                    <fieldset class="answer-group">
                        <ul class="answer-group__list">
                            {% for option in group.options %}
                            <li class="answer-group__item">
                                <input class="answer-group__input"
                                    type="radio"
                                    name="question-{{ groupIndex }}"
                                    id="question-{{ groupIndex }}-answer-{{ loop.index }}"
                                    value="{{ option.value or loop.index }}">
                                <label class="answer-group__label"
                                    for="question-{{ groupIndex }}-answer-{{ loop.index }}">{{ option.text | safe }}</label>
                            </li>
                            {% endfor %}
                        </ul>
                    </fieldset>
                </li>
                {% endfor %}
            </ul>
            {{ bottomActions({
                "elementClass": "answer-groups__bottom",
                "submitType": "submit",
                "submitText": props.submitText or "далее",
                "submitIcon": true,
                "backDisabled": true,
                "submitDisabled": true
            }) }}
        </form>
    </div>
</div>
{% endmacro %}

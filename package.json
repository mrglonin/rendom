{
  "name": "modern-layout-starter",
  "version": "2.0.0",
  "description": "Modern Gulp starter for static layout projects with blocks and page templates",
  "private": true,
  "scripts": {
    "dev": "node server/index.js",
    "start": "node server/index.js",
    "fonts": "node scripts/convert-fonts.js",
    "build": "gulp build",
    "clean": "gulp clean",
    "format": "npm run format:templates && npm run format:assets",
    "format:templates": "python3 scripts/format_njk.py",
    "format:assets": "prettier --write \"src/**/*.{js,scss,css,json}\" \"server/**/*.js\" \".vscode/*.json\" \"*.{json,md,yml}\""
  },
  "author": "Deorfeal",
  "license": "ISC",
  "browserslist": [
    "last 2 versions",
    "not dead",
    "not op_mini all"
  ],
  "devDependencies": {
    "aos": "^2.3.4",
    "autoprefixer": "^10.4.21",
    "browser-sync": "^3.0.4",
    "browserslist-to-esbuild": "^2.1.1",
    "cssnano": "^7.1.1",
    "del": "^6.1.1",
    "esbuild": "^0.25.11",
    "gulp": "^5.0.1",
    "gulp-data": "^1.3.1",
    "gulp-nunjucks-render": "^2.2.3",
    "gulp-plumber": "^1.2.1",
    "gulp-postcss": "^10.0.0",
    "gulp-sass": "^6.0.1",
    "prettier": "^3.6.2",
    "sass": "^1.93.2",
    "ttf2woff": "^3.0.0",
    "ttf2woff2": "^8.0.1"
  },
  "dependencies": {
    "express": "^5.1.0",
    "multer": "^2.0.2",
    "xlsx": "^0.18.5"
  }
}
